# Backend API base URL (used for REST calls — must include /api)
NEXT_PUBLIC_API_URL=http://localhost:5001/api

# Backend WebSocket URL (used for Socket.IO — root URL without /api)
# Optional: if not set, /api is automatically stripped from NEXT_PUBLIC_API_URL
NEXT_PUBLIC_WS_URL=http://localhost:5001

# Pipecat Cloud public start endpoint (agent URL without trailing /start)
NEXT_PUBLIC_PIPECAT_BOT_URL=https://api.pipecat.daily.co/v1/public/pipecat-quickstart

# Pipecat Cloud public key (pk_...) used from browser for /start
NEXT_PUBLIC_PIPECAT_BOT_KEY=