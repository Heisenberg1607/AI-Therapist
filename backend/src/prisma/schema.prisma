generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // transaction pooler (:6543) — app runtime
  directUrl = env("DIRECT_URL")   // session/direct connection (:5432) — migrations
}

model User{
  id        String @id @default (uuid())
  email     String @unique
  password  String? // hashed password
  name      String?
  image     String?
  onboarded      Boolean @default(false)
  onboardingData Json?   // stored onboarding answers, used to rebuild the prompt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessions  Session[]
  reports   Report[]
}

model Session {
  id          String   @id @default(uuid())
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String?  // link to user table
  createdAt   DateTime @default(now())
  messages    Message[]
  crisisFlag  Boolean  @default(false) @map("crisis_flag")
  summary     String?  // AI-generated post-session summary
  mood        String?  // mood at the START of the conversation, derived from the transcript (one of MOOD_LABELS)
  moodEnd     String?  // mood at the END of the conversation, derived from the transcript (one of MOOD_LABELS)
  topic       String?  // main topic (onboarding Q1)
  durationSec Int?     // session length in seconds
  ratingScores  Json?  // LLM-judge scores per metric (empathy, conciseness, …), each 1-5
  ratingOverall Float? // average of the metric scores (out of 5)
}

model Message {
  id         String   @id @default(uuid())
  session    Session  @relation(fields: [sessionId], references: [id])
  sessionId  String   // link to session table
  sender     Sender
  content    String
  createdAt  DateTime @default(now())
}

enum Sender {
  USER
  AI
}

enum ReportType {
  GENERATED
  UPLOADED
}

model Report {
  id               String     @id @default(uuid())
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  type             ReportType
  title            String
  summary          String? // markdown body (generated reports)
  mostCommonIssues String[]   @default([]) // generated reports
  filePath         String // {userId}/{id}.{ext} in the private `reports` bucket
  fileType         String // mime type
  createdAt        DateTime   @default(now())

  @@index([userId])
}
