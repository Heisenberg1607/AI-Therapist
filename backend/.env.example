# Database — app runtime uses the transaction pooler (port 6543, PgBouncer; avoids pool timeouts)
DATABASE_URL=postgresql://<user>:<password>@<host>:6543/<db>?pgbouncer=true&connection_limit=1
# Prisma MIGRATIONS must use a direct/session connection (port 5432). PgBouncer transaction
# mode can't hold the session advisory lock migrations need, so migrate deploy hangs on 6543.
# In Supabase: Project Settings → Database → use the "Session pooler" string (port 5432).
DIRECT_URL=postgresql://<user>:<password>@<host>:5432/<db>

# Auth
JWT_SECRET=your-64-char-random-secret-here

# OpenAI
OPENAI_API_KEY=sk-...

# ElevenLabs (TTS)
ELEVEN_LABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=ADd2WEtjmwokqUr0Y5Ad

# Server
PORT=5001

# CORS - set to your deployed frontend URL in production
FRONTEND_URL=http://localhost:3000

# Grafana Loki (production log aggregation — leave blank in development)
GRAFANA_LOKI_USERNAME=your-loki-instance-id
GRAFANA_LOKI_API_KEY=your-grafana-api-key

# Cekura (AI Agent Evaluation)
CEKURA_API_KEY=your-cekura-api-key
CEKURA_AGENT_ID=therapist-bot

# Supabase Storage (report files). Service role key: Supabase → Settings → API → service_role.
# Keep the service role key SECRET — it bypasses RLS. Server-side only, never expose to the client.
SUPABASE_URL=https://ekkcafpjpzwdyamonjtf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_REPORTS_BUCKET=reports